# WavEDA 本机安装路径。可选；填写后 agent 可以在本机 Example/helpHtml 中查找回答配图。
WAVEDA_ROOT=
# 例如：WAVEDA_ROOT=D:\Program Files\WavEDA

# WavEDA 帮助文档路径。默认使用项目自带帮助文档；如需调用本机帮助文档，请改成自己的绝对路径。
WAVEDA_HELP_ROOT=wavEDA_docs/helpHtml/helpHtml
# 例如：WAVEDA_HELP_ROOT=D:\Program Files\WavEDA\documentation\helpHtml

# WavEDA 案例目录。可选；如果不填，会优先尝试 WAVEDA_ROOT\Example。
WAVEDA_EXAMPLE_ROOT=
# 例如：WAVEDA_EXAMPLE_ROOT=D:\Program Files\WavEDA\Example
# OBSIDIAN_VAULT_ROOT=knowledge_base
# RAG_DATA_DIR=data

RAG_EMBEDDING_MODEL=local-hashed-vectors
RAG_LLM_BASE_URL=https://api.deepseek.com
RAG_LLM_API_KEY=
RAG_LLM_MODEL=deepseek-chat
